{
  "title": "Cluster Status",
  "uid": "rackman-status-page",
  "description": "At-a-glance health of all services, endpoints and nodes",
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "panels": [
    {
      "id": 1,
      "title": "Endpoint Health",
      "description": "HTTP probe result per service. Green = reachable, red = unreachable.",
      "type": "status-history",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "min_over_time(probe_success{job=\"blackbox\"}[$__interval])",
          "legendFormat": "{{instance}}",
          "instant": false,
          "queryType": "range"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 70,
            "lineWidth": 0,
            "spanNulls": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red" },
                "1": { "text": "UP", "color": "green" }
              }
            }
          ],
          "color": { "mode": "thresholds" }
        }
      },
      "options": {
        "colWidth": 0.9,
        "showValue": "never",
        "rowHeight": 0.8,
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": false },
        "tooltip": { "mode": "single" }
      }
    },
    {
      "id": 2,
      "title": "Endpoint Uptime % — Last 24h",
      "description": "Percentage of probes that succeeded over the dashboard time range.",
      "type": "stat",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "avg_over_time(probe_success{job=\"blackbox\"}[$__range]) * 100",
          "legendFormat": "{{instance}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 95 },
              { "color": "green", "value": 99.9 }
            ]
          },
          "color": { "mode": "thresholds" },
          "min": 0,
          "max": 100
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 3,
      "title": "Node Ready Status",
      "description": "kube_node_status_condition Ready=true per node. Green = ready, red = not ready.",
      "type": "status-history",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "min_over_time(kube_node_status_condition{condition=\"Ready\",status=\"true\"}[$__interval])",
          "legendFormat": "{{node}}",
          "instant": false,
          "queryType": "range"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 70,
            "lineWidth": 0,
            "spanNulls": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "NOT READY", "color": "red" },
                "1": { "text": "READY", "color": "green" }
              }
            }
          ],
          "color": { "mode": "thresholds" }
        }
      },
      "options": {
        "colWidth": 0.9,
        "showValue": "never",
        "rowHeight": 0.8,
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": false },
        "tooltip": { "mode": "single" }
      }
    },
    {
      "id": 4,
      "title": "Active Alerts",
      "description": "Currently firing Grafana alerts.",
      "type": "alertlist",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 22 },
      "options": {
        "alertInstanceLabelFilter": "",
        "alertName": "",
        "dashboardAlerts": false,
        "datasource": "grafana",
        "folder": {},
        "groupBy": [],
        "groupMode": "default",
        "maxItems": 20,
        "sortOrder": 1,
        "stateFilter": {
          "error": true,
          "firing": true,
          "noData": false,
          "normal": false,
          "pending": false
        },
        "viewMode": "list"
      }
    }
  ]
}
