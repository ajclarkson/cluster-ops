{
  "title": "Cluster Health",
  "uid": "rackman-cluster-health",
  "description": "Node health, pod status and recent incidents — rackman k3s cluster",
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "panels": [
    {
      "id": 1,
      "title": "Node Memory Used %",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "node_memory_working_set_bytes{job=\"integrations/kubernetes/resources\"} / on(node) max by (node) (kube_node_status_capacity{resource=\"memory\"}) * 100",
          "legendFormat": "{{ node }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 85 }
            ]
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "thresholdsStyle": { "mode": "line" }
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "id": 2,
      "title": "Node CPU Used %",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(node_cpu_usage_seconds_total{job=\"integrations/kubernetes/resources\"}[5m]) / on(node) max by (node) (kube_node_status_capacity{resource=\"cpu\"}) * 100",
          "legendFormat": "{{ node }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "id": 7,
      "title": "Node Disk Used %",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "(1 - node_filesystem_avail_bytes{job=\"integrations/node_exporter\", mountpoint=\"/\", fstype!~\"tmpfs|rootfs\"} / node_filesystem_size_bytes{job=\"integrations/node_exporter\", mountpoint=\"/\", fstype!~\"tmpfs|rootfs\"}) * 100",
          "legendFormat": "{{ instance }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "thresholdsStyle": { "mode": "line" }
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "id": 6,
      "title": "PVC Disk Used %",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "(1 - kubelet_volume_stats_available_bytes{job=\"integrations/kubernetes/kubelet\"} / kubelet_volume_stats_capacity_bytes{job=\"integrations/kubernetes/kubelet\"}) * 100",
          "legendFormat": "{{ namespace }}/{{ persistentvolumeclaim }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "thresholdsStyle": { "mode": "line" }
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "id": 8,
      "title": "Node Network Throughput",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(node_network_receive_bytes_total{job=\"integrations/node_exporter\", device!~\"lo|veth.*|cni.*|flannel.*|tunl.*\"}[5m])",
          "legendFormat": "{{ instance }} rx"
        },
        {
          "refId": "B",
          "expr": "rate(node_network_transmit_bytes_total{job=\"integrations/node_exporter\", device!~\"lo|veth.*|cni.*|flannel.*|tunl.*\"}[5m])",
          "legendFormat": "{{ instance }} tx"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "id": 3,
      "title": "Pod Restarts — Last 24h",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "increase(kube_pod_container_status_restarts_total{namespace!~\"kube-system\"}[24h]) > 0",
          "instant": true,
          "format": "table",
          "legendFormat": ""
        }
      ],
      "transformations": [
        {
          "id": "filterFieldsByName",
          "options": { "include": { "names": ["namespace", "pod", "container", "Value"] } }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": { "Value": "Restarts" }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Restarts" },
            "properties": [
              { "id": "decimals", "value": 0 },
              { "id": "custom.width", "value": 80 },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 2 },
                    { "color": "red", "value": 5 }
                  ]
                }
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          }
        ]
      },
      "options": {
        "sortBy": [{ "displayName": "Restarts", "desc": true }],
        "footer": { "show": false }
      }
    },
    {
      "id": 4,
      "title": "Pods Not Running",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "kube_pod_status_phase{phase!~\"Running|Succeeded\"} == 1",
          "instant": true,
          "format": "table",
          "legendFormat": ""
        }
      ],
      "transformations": [
        {
          "id": "filterFieldsByName",
          "options": { "include": { "names": ["namespace", "pod", "phase"] } }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "phase" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "Pending": { "color": "yellow", "index": 0 } } },
                  { "type": "value", "options": { "Failed": { "color": "red", "index": 1 } } },
                  { "type": "value", "options": { "Unknown": { "color": "orange", "index": 2 } } }
                ]
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          }
        ]
      },
      "options": { "footer": { "show": false } }
    },
    {
      "id": 5,
      "title": "Recent OOM Events",
      "type": "logs",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 32 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "{node!=\"\"} |= \"System OOM encountered\"",
          "queryType": "range"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    },
    {
      "id": 9,
      "title": "Container Memory % of Limit — Top 10",
      "description": "Containers closest to their memory limits right now. Red = >90%, yellow = >75%.",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, container_memory_working_set_bytes{container!=\"\", container!=\"POD\"} / on(namespace, pod, container) max by (namespace, pod, container) (kube_pod_container_resource_limits{resource=\"memory\", container!=\"\", container!=\"POD\"}) * 100)",
          "instant": true,
          "format": "table",
          "legendFormat": ""
        }
      ],
      "transformations": [
        {
          "id": "filterFieldsByName",
          "options": { "include": { "names": ["namespace", "pod", "container", "Value"] } }
        },
        {
          "id": "organize",
          "options": { "renameByName": { "Value": "Mem % of Limit" } }
        },
        {
          "id": "sortBy",
          "options": { "fields": [{ "displayName": "Mem % of Limit", "desc": true }] }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Mem % of Limit" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "decimals", "value": 1 },
              { "id": "custom.width", "value": 130 },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 75 },
                    { "color": "red", "value": 90 }
                  ]
                }
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "namespace" },
            "properties": [{ "id": "custom.width", "value": 140 }]
          },
          {
            "matcher": { "id": "byName", "options": "container" },
            "properties": [{ "id": "custom.width", "value": 140 }]
          }
        ]
      },
      "options": { "footer": { "show": false } }
    },
    {
      "id": 10,
      "title": "Container Memory % of Limit — Known Offenders",
      "description": "Memory pressure trend for containers with a history of OOM kills: alloy-metrics, loki-backend, longhorn-manager.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "(\n  container_memory_working_set_bytes{container!=\"\", container!=\"POD\", namespace=~\"k8s-monitoring|loki|longhorn-system\", container=~\"alloy|loki|longhorn-manager\"}\n  / on(namespace, pod, container)\n  max by (namespace, pod, container) (kube_pod_container_resource_limits{resource=\"memory\", container!=\"\", container!=\"POD\"})\n) * 100",
          "legendFormat": "{{ namespace }}/{{ container }} ({{ pod }})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "thresholdsStyle": { "mode": "line" }
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "id": 11,
      "title": "Nearest Cert Expiry (days)",
      "description": "Days until the soonest-expiring k3s control-plane certificate. Alert fires at <90 days.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 48 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "min((x509_cert_not_after{job=\"x509-certificate-exporter\"} - time()) / 86400)",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "horizontal",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "noValue": "N/A",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "green", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "id": 12,
      "title": "Recent Cluster Warning Events",
      "description": "All Kubernetes Warning-level events from across the cluster. Useful for catching issues not yet covered by alerts.",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 52 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "{job=\"integrations/kubernetes/eventhandler\", level=\"Warning\"}",
          "queryType": "range"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    },
    {
      "id": 13,
      "title": "Reloader — Rollouts Triggered",
      "description": "Counts of pod rollouts triggered by Reloader when a Secret or ConfigMap data hash changed.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 62 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "increase(reloader_reload_executed_total{success=\"true\"}[$__interval])",
          "legendFormat": "success"
        },
        {
          "refId": "B",
          "expr": "increase(reloader_reload_executed_total{success=\"false\"}[$__interval])",
          "legendFormat": "failed"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "drawStyle": "bars"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "failed" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "success" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    }
  ]
}
