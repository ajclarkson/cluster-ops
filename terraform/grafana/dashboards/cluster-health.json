{
  "title": "Cluster Health",
  "uid": "rackman-cluster-health",
  "description": "Node health, pod status and recent incidents — rackman k3s cluster",
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "panels": [
    {
      "id": 1,
      "title": "Node Memory Used %",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "node_memory_working_set_bytes{job=\"integrations/kubernetes/resources\"} / on(node) kube_node_status_capacity{resource=\"memory\"} * 100",
          "legendFormat": "{{ node }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 85 }
            ]
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "thresholdsStyle": { "mode": "line" }
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "id": 2,
      "title": "Node CPU Used %",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(node_cpu_usage_seconds_total{job=\"integrations/kubernetes/resources\"}[5m]) / on(node) kube_node_status_capacity{resource=\"cpu\"} * 100",
          "legendFormat": "{{ node }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "id": 7,
      "title": "Node Disk Used %",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "(1 - node_filesystem_avail_bytes{job=\"integrations/node_exporter\", mountpoint=\"/\", fstype!~\"tmpfs|rootfs\"} / node_filesystem_size_bytes{job=\"integrations/node_exporter\", mountpoint=\"/\", fstype!~\"tmpfs|rootfs\"}) * 100",
          "legendFormat": "{{ instance }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "thresholdsStyle": { "mode": "line" }
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "id": 6,
      "title": "PVC Disk Used %",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "(1 - kubelet_volume_stats_available_bytes{job=\"integrations/kubernetes/kubelet\"} / kubelet_volume_stats_capacity_bytes{job=\"integrations/kubernetes/kubelet\"}) * 100",
          "legendFormat": "{{ namespace }}/{{ persistentvolumeclaim }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "thresholdsStyle": { "mode": "line" }
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "id": 8,
      "title": "Node Network Throughput",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(node_network_receive_bytes_total{job=\"integrations/node_exporter\", device!~\"lo|veth.*|cni.*|flannel.*|tunl.*\"}[5m])",
          "legendFormat": "{{ instance }} rx"
        },
        {
          "refId": "B",
          "expr": "rate(node_network_transmit_bytes_total{job=\"integrations/node_exporter\", device!~\"lo|veth.*|cni.*|flannel.*|tunl.*\"}[5m])",
          "legendFormat": "{{ instance }} tx"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "id": 3,
      "title": "Pod Restarts — Last 24h",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "increase(kube_pod_container_status_restarts_total{namespace!~\"kube-system\"}[24h]) > 0",
          "instant": true,
          "format": "table",
          "legendFormat": ""
        }
      ],
      "transformations": [
        {
          "id": "filterFieldsByName",
          "options": { "include": { "names": ["namespace", "pod", "container", "Value"] } }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": { "Value": "Restarts" }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Restarts" },
            "properties": [
              { "id": "decimals", "value": 0 },
              { "id": "custom.width", "value": 80 },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 2 },
                    { "color": "red", "value": 5 }
                  ]
                }
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          }
        ]
      },
      "options": {
        "sortBy": [{ "displayName": "Restarts", "desc": true }],
        "footer": { "show": false }
      }
    },
    {
      "id": 4,
      "title": "Pods Not Running",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "kube_pod_status_phase{phase!~\"Running|Succeeded\"} == 1",
          "instant": true,
          "format": "table",
          "legendFormat": ""
        }
      ],
      "transformations": [
        {
          "id": "filterFieldsByName",
          "options": { "include": { "names": ["namespace", "pod", "phase"] } }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "phase" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "Pending": { "color": "yellow", "index": 0 } } },
                  { "type": "value", "options": { "Failed": { "color": "red", "index": 1 } } },
                  { "type": "value", "options": { "Unknown": { "color": "orange", "index": 2 } } }
                ]
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          }
        ]
      },
      "options": { "footer": { "show": false } }
    },
    {
      "id": 5,
      "title": "Recent OOM Events",
      "type": "logs",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 48 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "{node!=\"\"} |= \"System OOM encountered\"",
          "queryType": "range"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    }
  ]
}
