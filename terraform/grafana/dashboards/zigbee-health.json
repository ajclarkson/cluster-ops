{
  "title": "Zigbee Network Health",
  "uid": "rackman-zigbee-health",
  "description": "Zigbee2MQTT bridge, device availability, battery levels and link quality",
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "5m",
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "panels": [
    {
      "id": 1,
      "title": "Bridge",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "zigbee2mqtt_bridge_state",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name",
        "text": {}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Offline", "color": "red", "index": 0 } } },
            { "type": "value", "options": { "1": { "text": "Online",  "color": "green", "index": 1 } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      }
    },
    {
      "id": 2,
      "title": "Devices Online",
      "type": "stat",
      "gridPos": { "h": 4, "w": 5, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(zigbee2mqtt_device_up)",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      }
    },
    {
      "id": 3,
      "title": "Devices Offline",
      "type": "stat",
      "gridPos": { "h": 4, "w": 5, "x": 9, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "count(zigbee2mqtt_device_up == 0) or vector(0)",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "OTA Updates Available",
      "type": "stat",
      "gridPos": { "h": 4, "w": 5, "x": 14, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "count(zigbee2mqtt_device_ota{state=\"available\"} == 1) or vector(0)",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Low Battery (< 20%)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 5, "x": 19, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "count(zigbee2mqtt_device_battery_level < 20) or vector(0)",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Offline Devices",
      "description": "Devices currently reporting offline. Empty is healthy.",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "zigbee2mqtt_device_up == 0",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        { "id": "filterFieldsByName", "options": { "include": { "names": ["device"] } } }
      ],
      "fieldConfig": { "defaults": {} },
      "options": { "footer": { "show": false } }
    },
    {
      "id": 7,
      "title": "OTA Updates Available",
      "description": "Devices with firmware updates ready to install.",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "zigbee2mqtt_device_ota{state=\"available\"} == 1",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        { "id": "filterFieldsByName", "options": { "include": { "names": ["device"] } } }
      ],
      "fieldConfig": { "defaults": {} },
      "options": { "footer": { "show": false } }
    },
    {
      "id": 8,
      "title": "Battery Levels",
      "description": "All battery-powered devices sorted by charge level.",
      "type": "table",
      "gridPos": { "h": 12, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "zigbee2mqtt_device_battery_level",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        { "id": "filterFieldsByName", "options": { "include": { "names": ["device", "Value"] } } },
        { "id": "organize", "options": { "renameByName": { "Value": "Battery %" } } }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Battery %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "decimals", "value": 0 },
              { "id": "custom.width", "value": 100 },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "yellow", "value": 20 },
                    { "color": "green", "value": 50 }
                  ]
                }
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          }
        ]
      },
      "options": {
        "sortBy": [{ "displayName": "Battery %", "desc": false }],
        "footer": { "show": false }
      }
    },
    {
      "id": 9,
      "title": "Link Quality",
      "description": "Signal strength per device (0–255). Higher is better.",
      "type": "table",
      "gridPos": { "h": 12, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "zigbee2mqtt_device_link_quality",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        { "id": "filterFieldsByName", "options": { "include": { "names": ["device", "Value"] } } },
        { "id": "organize", "options": { "renameByName": { "Value": "LQI" } } }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "LQI" },
            "properties": [
              { "id": "decimals", "value": 0 },
              { "id": "min", "value": 0 },
              { "id": "max", "value": 255 },
              { "id": "custom.width", "value": 80 },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "yellow", "value": 30 },
                    { "color": "green", "value": 80 }
                  ]
                }
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          }
        ]
      },
      "options": {
        "sortBy": [{ "displayName": "LQI", "desc": false }],
        "footer": { "show": false }
      }
    }
  ]
}
