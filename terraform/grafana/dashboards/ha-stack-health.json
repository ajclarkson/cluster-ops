{
  "title": "Home Automation Stack Health",
  "uid": "rackman-ha-stack-health",
  "description": "Service health and platform metrics for homerun, home-assistant, zigbee2mqtt and mosquitto",
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "panels": [
    {
      "id": 1,
      "title": "Home Assistant — restarts (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 5, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(kube_pod_container_status_restarts_total{namespace=\"home-assistant\", container=\"home-assistant\"}[24h]))",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "horizontal"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red",    "value": 3 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Zigbee2MQTT — restarts (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 5, "x": 5, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(kube_pod_container_status_restarts_total{namespace=\"zigbee2mqtt\", container=\"zigbee2mqtt\"}[24h]))",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "horizontal"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red",    "value": 3 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Mosquitto — restarts (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 5, "x": 10, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(kube_pod_container_status_restarts_total{namespace=\"mqtt\", container=\"mosquitto\"}[24h]))",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "horizontal"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red",    "value": 3 }
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "title": "homerun — restarts (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 5, "x": 15, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(kube_pod_container_status_restarts_total{namespace=\"homerun\", container=\"homerun\"}[24h]))",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "horizontal"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red",    "value": 3 }
            ]
          }
        }
      }
    },
    {
      "id": 9,
      "title": "Automations loaded",
      "description": "Number of automations currently loaded by homerun. A sudden drop indicates a reload failure.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "homerun_automations_loaded",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green",  "value": 40 }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "title": "HA event ingestion rate",
      "description": "Rate of events received from Home Assistant by event type.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(homerun_ha_events_received_total[5m])",
          "legendFormat": "{{ event_type }}",
          "instant": false,
          "queryType": "range"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "id": 11,
      "title": "Pipeline runs by trigger type",
      "description": "What is driving automation runs — sensor events, schedules, button presses or startup.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (trigger_type) (rate(homerun_pipeline_runs_total[5m]))",
          "legendFormat": "{{ trigger_type }}",
          "instant": false,
          "queryType": "range"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "drawStyle": "bars",
            "barAlignment": 0,
            "stacking": { "mode": "normal", "group": "A" }
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "id": 12,
      "title": "Action outcomes",
      "description": "Dispatched, succeeded and failed actions over time. Succeeded and dispatched should track closely.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(homerun_actions_dispatched_total[5m]))",
          "legendFormat": "dispatched",
          "instant": false,
          "queryType": "range"
        },
        {
          "refId": "B",
          "expr": "sum(rate(homerun_actions_succeeded_total[5m]))",
          "legendFormat": "succeeded",
          "instant": false,
          "queryType": "range"
        },
        {
          "refId": "C",
          "expr": "sum(rate(homerun_actions_failed_total[5m]))",
          "legendFormat": "failed",
          "instant": false,
          "queryType": "range"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "failed" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "succeeded" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "id": 13,
      "title": "Action duration — p50 / p95",
      "description": "Execution latency by action type. p95 spikes may indicate HA or MQTT slowness.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (action_type, le) (rate(homerun_action_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{ action_type }}",
          "instant": false,
          "queryType": "range"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (action_type, le) (rate(homerun_action_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{ action_type }}",
          "instant": false,
          "queryType": "range"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "id": 5,
      "title": "Container memory",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (namespace, container) (container_memory_working_set_bytes{namespace=~\"home-assistant|zigbee2mqtt|mqtt|homerun\", container=~\"home-assistant|zigbee2mqtt|mosquitto|homerun\"})",
          "legendFormat": "{{ namespace }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "id": 6,
      "title": "Error rate by service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({namespace=\"home-assistant\"} |= \"ERROR\" != \"async_upnp_client.ssdp\" [5m]))",
          "legendFormat": "home-assistant",
          "queryType": "range"
        },
        {
          "refId": "B",
          "expr": "sum(count_over_time({namespace=\"zigbee2mqtt\"} |~ \"\\\\[31m\" [5m]))",
          "legendFormat": "zigbee2mqtt",
          "queryType": "range"
        },
        {
          "refId": "C",
          "expr": "sum(count_over_time({namespace=\"homerun\"} |= \"ERROR\" [5m]))",
          "legendFormat": "homerun",
          "queryType": "range"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "drawStyle": "bars"
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "id": 7,
      "title": "Recent errors",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 36 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "{namespace=\"home-assistant\"} |= \"ERROR\" != \"async_upnp_client.ssdp\" | line_format \"[home-assistant] {{__line__}}\"",
          "queryType": "range"
        },
        {
          "refId": "B",
          "expr": "{namespace=\"zigbee2mqtt\"} |~ \"\\\\[31m\" | line_format \"[zigbee2mqtt] {{__line__}}\"",
          "queryType": "range"
        },
        {
          "refId": "C",
          "expr": "{namespace=\"homerun\"} |= \"ERROR\" | line_format \"[homerun] {{__line__}}\"",
          "queryType": "range"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true,
        "displayedFields": []
      }
    }
  ]
}
