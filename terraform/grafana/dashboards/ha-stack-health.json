{
  "title": "Home Automation Stack Health",
  "uid": "rackman-ha-stack-health",
  "description": "Service health for home-assistant, zigbee2mqtt, homerun and mosquitto",
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "panels": [
    {
      "id": 1,
      "title": "Home Assistant — restarts (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(kube_pod_container_status_restarts_total{namespace=\"home-assistant\", container=\"home-assistant\"}[24h]))",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "horizontal"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Zigbee2MQTT — restarts (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(kube_pod_container_status_restarts_total{namespace=\"zigbee2mqtt\", container=\"zigbee2mqtt\"}[24h]))",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "horizontal"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Mosquitto — restarts (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(kube_pod_container_status_restarts_total{namespace=\"mqtt\", container=\"mosquitto\"}[24h]))",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "horizontal"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "title": "homerun — restarts (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(kube_pod_container_status_restarts_total{namespace=\"homerun\", container=\"homerun\"}[24h]))",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "horizontal"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Container Memory",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (namespace, container) (container_memory_working_set_bytes{namespace=~\"home-assistant|zigbee2mqtt|mqtt|homerun\", container=~\"home-assistant|zigbee2mqtt|mosquitto|homerun\"})",
          "legendFormat": "{{ namespace }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "id": 6,
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({namespace=\"home-assistant\"} |= \"ERROR\" != \"async_upnp_client.ssdp\" [5m]))",
          "legendFormat": "home-assistant",
          "queryType": "range"
        },
        {
          "refId": "B",
          "expr": "sum(count_over_time({namespace=\"zigbee2mqtt\"} |~ \"\\\\[31m\" [5m]))",
          "legendFormat": "zigbee2mqtt",
          "queryType": "range"
        },
        {
          "refId": "C",
          "expr": "sum(count_over_time({namespace=\"homerun\"} |= \"ERROR\" [5m]))",
          "legendFormat": "homerun",
          "queryType": "range"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "drawStyle": "bars"
          },
          "min": 0
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "id": 7,
      "title": "Recent Errors",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "{namespace=\"home-assistant\"} |= \"ERROR\" != \"async_upnp_client.ssdp\" | line_format \"[home-assistant] {{__line__}}\"",
          "queryType": "range"
        },
        {
          "refId": "B",
          "expr": "{namespace=\"zigbee2mqtt\"} |~ \"\\\\[31m\" | line_format \"[zigbee2mqtt] {{__line__}}\"",
          "queryType": "range"
        },
        {
          "refId": "C",
          "expr": "{namespace=\"homerun\"} |= \"ERROR\" | line_format \"[homerun] {{__line__}}\"",
          "queryType": "range"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true,
        "displayedFields": []
      }
    }
  ]
}
