{
  "title": "Home Automation Behaviour",
  "uid": "rackman-ha-behaviour",
  "description": "What the house is doing and why",
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "5m",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "location",
        "type": "custom",
        "label": "Room",
        "query": ".*,bathroom,bedroom,foreign_office,hallway_downstairs,hallway_upstairs,home_office,house,kitchen,parlour",
        "options": [
          {
            "selected": true,
            "text": "All",
            "value": ".*"
          },
          {
            "selected": false,
            "text": "bathroom",
            "value": "bathroom"
          },
          {
            "selected": false,
            "text": "bedroom",
            "value": "bedroom"
          },
          {
            "selected": false,
            "text": "foreign_office",
            "value": "foreign_office"
          },
          {
            "selected": false,
            "text": "hallway_downstairs",
            "value": "hallway_downstairs"
          },
          {
            "selected": false,
            "text": "hallway_upstairs",
            "value": "hallway_upstairs"
          },
          {
            "selected": false,
            "text": "home_office",
            "value": "home_office"
          },
          {
            "selected": false,
            "text": "house",
            "value": "house"
          },
          {
            "selected": false,
            "text": "kitchen",
            "value": "kitchen"
          },
          {
            "selected": false,
            "text": "parlour",
            "value": "parlour"
          }
        ],
        "current": {
          "selected": true,
          "text": "All",
          "value": ".*"
        },
        "includeAll": false,
        "hide": 0
      },
      {
        "name": "subsystem",
        "type": "custom",
        "label": "Subsystem",
        "query": ".*,camera,heating,hold_sync,house_mode,lighting,occupied,sonos,window_thermal",
        "options": [
          {
            "selected": true,
            "text": "All",
            "value": ".*"
          },
          {
            "selected": false,
            "text": "camera",
            "value": "camera"
          },
          {
            "selected": false,
            "text": "heating",
            "value": "heating"
          },
          {
            "selected": false,
            "text": "hold_sync",
            "value": "hold_sync"
          },
          {
            "selected": false,
            "text": "house_mode",
            "value": "house_mode"
          },
          {
            "selected": false,
            "text": "lighting",
            "value": "lighting"
          },
          {
            "selected": false,
            "text": "occupied",
            "value": "occupied"
          },
          {
            "selected": false,
            "text": "sonos",
            "value": "sonos"
          },
          {
            "selected": false,
            "text": "window_thermal",
            "value": "window_thermal"
          }
        ],
        "current": {
          "selected": true,
          "text": "All",
          "value": ".*"
        },
        "includeAll": false,
        "hide": 0
      },
      {
        "name": "decision_filter",
        "type": "custom",
        "label": "Show",
        "query": "Changes only : no_change,All : __none__",
        "options": [
          {
            "selected": true,
            "text": "Changes only",
            "value": "no_change"
          },
          {
            "selected": false,
            "text": "All",
            "value": "__none__"
          }
        ],
        "current": {
          "selected": true,
          "text": "Changes only",
          "value": "no_change"
        },
        "includeAll": false,
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Decisions today",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({service_name=\"loki.source.kubernetes.home_events\", event_type=\"decision\", location=~\"$location\", subsystem=~\"$subsystem\"} | json | decision !~ \"$decision_filter\" | reason !~ \"$decision_filter\" [24h]))",
          "queryType": "range"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Errors today",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({service_name=\"loki.source.kubernetes.home_events\", outputs_result=\"error\", location=~\"$location\", subsystem=~\"$subsystem\"} [24h]))",
          "queryType": "range"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Lighting — active (2h)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({service_name=\"loki.source.kubernetes.home_events\", event_type=\"decision\", subsystem=\"lighting\", location=~\"$location\"} | json | decision !~ \"$decision_filter\" | reason !~ \"$decision_filter\" [2h]))",
          "queryType": "range"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Occupancy — active (2h)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 15,
        "y": 0
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({service_name=\"loki.source.kubernetes.home_events\", event_type=\"decision\", subsystem=\"occupied\", location=~\"$location\"} | json | decision !~ \"$decision_filter\" | reason !~ \"$decision_filter\" [2h]))",
          "queryType": "range"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
