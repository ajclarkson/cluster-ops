    {
      "id": 28,
      "title": "Correlation trace",
      "description": "Paste a correlation_id, root_correlation_id, or parent_correlation_id into the variable above to see every event in that causal chain, in order — e.g. a decision, the mqtt.publish action it dispatched, the state_changed that action implied, and whatever automation that state_changed triggered next. Ignores the location/subsystem/activity filters deliberately, since a chain can cross both.",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 63 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "{service_name=\"loki.source.kubernetes.home_events\"} |~ \"$correlation_id\" | json | line_format \"[{{.location}}] {{.subsystem}} · {{.automation_id}} → {{.event_type}}{{if .decision}} {{.decision}} ({{.reason}}){{end}}{{if .abort_kind}} {{.abort_kind}}{{end}}{{if .action_type}} {{.action_type}} [{{.status}}]{{end}}\"",
          "queryType": "range"
        }
      ],
      "options": {
