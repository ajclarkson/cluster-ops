    {
      "id": 9,
      "title": "Heating — active (2h)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 21,
        "y": 0
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({service_name=\"loki.source.kubernetes.home_events\", event_type=\"decision\", subsystem=\"heating\", location=~\"$location\"} | json | decision !~ \"$decision_filter\" | reason !~ \"$decision_filter\" [2h]))",
          "queryType": "range"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
