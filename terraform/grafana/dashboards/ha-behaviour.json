{
  "title": "Home Automation Behaviour",
  "uid": "rackman-ha-behaviour",
  "description": "What the house is doing and why",
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "5m",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "location",
        "type": "custom",
        "label": "Room",
        "query": ".*,back_garden,bathroom,bedroom,foreign_office,hallway_downstairs,hallway_upstairs,home_office,house,kitchen,parlour",
        "options": [
          { "selected": true,  "text": "All",                 "value": ".*" },
          { "selected": false, "text": "back_garden",         "value": "back_garden" },
          { "selected": false, "text": "bathroom",            "value": "bathroom" },
          { "selected": false, "text": "bedroom",             "value": "bedroom" },
          { "selected": false, "text": "foreign_office",      "value": "foreign_office" },
          { "selected": false, "text": "hallway_downstairs",  "value": "hallway_downstairs" },
          { "selected": false, "text": "hallway_upstairs",    "value": "hallway_upstairs" },
          { "selected": false, "text": "home_office",         "value": "home_office" },
          { "selected": false, "text": "house",               "value": "house" },
          { "selected": false, "text": "kitchen",             "value": "kitchen" },
          { "selected": false, "text": "parlour",             "value": "parlour" }
        ],
        "current": { "selected": true, "text": "All", "value": ".*" },
        "includeAll": false,
        "hide": 0
      },
      {
        "name": "subsystem",
        "type": "custom",
        "label": "Subsystem",
        "query": ".*,cameras,energy,heating,house_mode,lighting,mo,occupied,sonos,thermal,wfh_inference",
        "options": [
          { "selected": true,  "text": "All",           "value": ".*" },
          { "selected": false, "text": "cameras",       "value": "cameras" },
          { "selected": false, "text": "energy",        "value": "energy" },
          { "selected": false, "text": "heating",       "value": "heating" },
          { "selected": false, "text": "house_mode",    "value": "house_mode" },
          { "selected": false, "text": "lighting",      "value": "lighting" },
          { "selected": false, "text": "mo",            "value": "mo" },
          { "selected": false, "text": "occupied",      "value": "occupied" },
          { "selected": false, "text": "sonos",         "value": "sonos" },
          { "selected": false, "text": "thermal",       "value": "thermal" },
          { "selected": false, "text": "wfh_inference", "value": "wfh_inference" }
        ],
        "current": { "selected": true, "text": "All", "value": ".*" },
        "includeAll": false,
        "hide": 0
      },
      {
        "name": "activity_filter",
        "type": "custom",
        "label": "Log filter",
        "description": "Filters on the framework-computed hasAction field (actions.length > 0), not on matching decision/reason strings — robust across every automation's own no-op vocabulary (no_change, no_action, already_on, ...).",
        "query": "Actions only : true,All : .*",
        "options": [
          { "selected": true,  "text": "Actions only", "value": "true" },
          { "selected": false, "text": "All",          "value": ".*" }
        ],
        "current": { "selected": true, "text": "Actions only", "value": "true" },
        "includeAll": false,
        "hide": 0
      },
      {
        "name": "correlation_id",
        "type": "textbox",
        "label": "Correlation ID",
        "description": "Paste a correlation_id, root_correlation_id, or parent_correlation_id to trace a full causal chain in the \"Correlation trace\" panel below.",
        "query": "",
        "current": { "value": "", "text": "" },
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Decisions today",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({service_name=\"loki.source.kubernetes.home_events\", event_type=\"decision\", location=~\"$location\", subsystem=~\"$subsystem\"} | json | hasAction=~\"$activity_filter\" [24h]))",
          "queryType": "range"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      }
    },
    {
      "id": 26,
      "title": "Aborts today",
      "description": "Pipeline runs that aborted before reaching a decision — disabled automations, guard condition errors, or explicit abort() calls.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({service_name=\"loki.source.kubernetes.home_events\", event_type=\"abort\", location=~\"$location\", subsystem=~\"$subsystem\"} [24h]))",
          "queryType": "range"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red",    "value": 10 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Errors today",
      "description": "Failed action executions (homerun_actions_failed_total), filtered by location only — this metric has no subsystem label. See the \"Automation errors\" log panel below for subsystem-scoped detail on individual failures.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(homerun_actions_failed_total{location=~\"$location\"}[24h]))",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 15,
      "title": "Action success rate (1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(homerun_actions_succeeded_total{location=~\"$location\"}[1h])) / sum(rate(homerun_actions_dispatched_total{location=~\"$location\"}[1h])) * 100",
          "instant": false,
          "queryType": "range"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "noValue": "—",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green",  "value": 99 }
            ]
          }
        }
      }
    },
    {
      "id": 20,
      "title": "Pipeline runs today",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(homerun_pipeline_runs_total{location=~\"$location\"}[24h]))",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "noValue": "0",
          "color": { "mode": "fixed", "fixedColor": "purple" }
        }
      }
    },
    {
      "id": 21,
      "title": "Automations loaded",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "homerun_automations_loaded",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green",  "value": 40 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Decision rate by subsystem",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (subsystem) (count_over_time({service_name=\"loki.source.kubernetes.home_events\", event_type=\"decision\", location=~\"$location\", subsystem=~\"$subsystem\"} | json | hasAction=~\"$activity_filter\" [10m]))",
          "legendFormat": "{{ subsystem }}",
          "queryType": "range"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "drawStyle": "bars",
            "barAlignment": 0
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "id": 14,
      "title": "Pipeline runs by location",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (location) (rate(homerun_pipeline_runs_total{location=~\"$location\"}[5m]))",
          "legendFormat": "{{ location }}",
          "instant": false,
          "queryType": "range"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "drawStyle": "bars",
            "barAlignment": 0
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "id": 22,
      "title": "What triggered runs",
      "description": "Breakdown of pipeline runs by trigger type — distinguishes scheduled automations from sensor-driven ones.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (trigger_type) (rate(homerun_pipeline_runs_total{location=~\"$location\"}[5m]))",
          "legendFormat": "{{ trigger_type }}",
          "instant": false,
          "queryType": "range"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "drawStyle": "bars",
            "barAlignment": 0,
            "stacking": { "mode": "normal", "group": "A" }
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "id": 23,
      "title": "Failed actions by type",
      "description": "Action failures broken down by action_type. Should be empty in normal operation.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (action_type) (rate(homerun_actions_failed_total{location=~\"$location\"}[5m]))",
          "legendFormat": "{{ action_type }}",
          "instant": false,
          "queryType": "range"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "drawStyle": "bars",
            "barAlignment": 0
          },
          "color": { "mode": "fixed", "fixedColor": "red" }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "id": 17,
      "title": "Action duration p95",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "cf6z4wiex30u8e" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (action_type, le) (rate(homerun_action_duration_seconds_bucket{location=~\"$location\"}[5m])))",
          "legendFormat": "{{ action_type }}",
          "instant": false,
          "queryType": "range"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "id": 3,
      "title": "Lighting — active (2h)",
      "type": "stat",
      "gridPos": { "h": 3, "w": 4, "x": 0, "y": 20 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({service_name=\"loki.source.kubernetes.home_events\", event_type=\"decision\", subsystem=\"lighting\", location=~\"$location\"} | json | hasAction=~\"$activity_filter\" [2h]))",
          "queryType": "range"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Occupancy — active (2h)",
      "type": "stat",
      "gridPos": { "h": 3, "w": 4, "x": 4, "y": 20 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({service_name=\"loki.source.kubernetes.home_events\", event_type=\"decision\", subsystem=\"occupied\", location=~\"$location\"} | json | hasAction=~\"$activity_filter\" [2h]))",
          "queryType": "range"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 9,
      "title": "Heating — active (2h)",
      "type": "stat",
      "gridPos": { "h": 3, "w": 4, "x": 8, "y": 20 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({service_name=\"loki.source.kubernetes.home_events\", event_type=\"decision\", subsystem=\"heating\", location=~\"$location\"} | json | hasAction=~\"$activity_filter\" [2h]))",
          "queryType": "range"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Sonos — active (2h)",
      "type": "stat",
      "gridPos": { "h": 3, "w": 4, "x": 12, "y": 20 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({service_name=\"loki.source.kubernetes.home_events\", event_type=\"decision\", subsystem=\"sonos\", location=~\"$location\"} | json | hasAction=~\"$activity_filter\" [2h]))",
          "queryType": "range"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 24,
      "title": "Cameras — active (2h)",
      "type": "stat",
      "gridPos": { "h": 3, "w": 4, "x": 16, "y": 20 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({service_name=\"loki.source.kubernetes.home_events\", event_type=\"decision\", subsystem=\"cameras\"} | json | hasAction=~\"$activity_filter\" [2h]))",
          "queryType": "range"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
