            ]
          }
        }
      }
    },
    {
      "id": 25,
      "title": "House mode — changes (2h)",
      "type": "stat",
      "gridPos": { "h": 3, "w": 4, "x": 20, "y": 20 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({service_name=\"loki.source.kubernetes.home_events\", event_type=\"decision\", subsystem=\"house_mode\"} | json | decision !~ \"no_change\" [2h]))",
          "queryType": "range"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "noValue": "0",
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      }
    },
    {
      "id": 7,
      "title": "Recent decisions",
      "description": "What the house decided to do and why. Expand any row for full conditions context.",
      "type": "logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 23 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "{service_name=\"loki.source.kubernetes.home_events\", event_type=\"decision\", location=~\"$location\", subsystem=~\"$subsystem\"} | json | hasAction=~\"$activity_filter\" | line_format \"[{{.location}}] {{.subsystem}} → {{.decision}} · {{.reason}} (via {{.trigger_type}}{{if .trigger_entity_id}}: {{.trigger_entity_id}}{{end}})\"",
          "queryType": "range"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      }
    },
    {
      "id": 27,
      "title": "Recent aborts",
      "description": "Pipelines that aborted before making a decision, classified by abort_kind: disabled (automation turned off), unhandled_error (exception during context/reduce), or guard (an explicit abort() call from the automation logic — reason is only populated for this kind).",
      "type": "logs",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 35 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "{service_name=\"loki.source.kubernetes.home_events\", event_type=\"abort\", location=~\"$location\", subsystem=~\"$subsystem\"} | json | line_format \"[{{.location}}] {{.subsystem}} — {{.abort_kind}}{{if .reason}}: {{.reason}}{{end}}\"",
          "queryType": "range"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      }
    },
    {
      "id": 8,
      "title": "Automation errors",
      "description": "action_result events where status = error. Should be empty in normal operation.",
      "type": "logs",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 43 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "{service_name=\"loki.source.kubernetes.home_events\", event_type=\"action_result\", location=~\"$location\", subsystem=~\"$subsystem\"} | json | status=\"error\" | line_format \"[{{.location}}] {{.subsystem}} · {{.automation_id}} → {{.action_type}} failed: {{.error}}\"",
          "queryType": "range"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    },
    {
      "id": 29,
      "title": "Ack timeouts today",
      "description": "Dispatched ha.call_service actions whose target entity never reached the expected state within homerun's commandAck timeout — device unreachable, Zigbee mesh failure, or HA accepting the call but nothing responding.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 51 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({service_name=\"loki.source.kubernetes.home_events\", event_type=\"action_ack_timeout\", location=~\"$location\", subsystem=~\"$subsystem\"} [24h]))",
          "queryType": "range"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red",    "value": 10 }
            ]
          }
        }
      }
    },
    {
      "id": 30,
