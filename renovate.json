{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "dependencyDashboard": true,
  "minimumReleaseAge": "3 days",
  "labels": [
    "dependencies"
  ],
  "packageRules": [
    {
      "matchUpdateTypes": ["major"],
      "labels": ["major"]
    },
    {
      "matchUpdateTypes": ["minor"],
      "labels": ["minor"]
    },
    {
      "matchUpdateTypes": ["patch"],
      "labels": ["patch"]
    },
    {
      "matchUpdateTypes": ["digest"],
      "automerge": true,
      "minimumReleaseAge": "0 days",
      "schedule": ["every weekend"]
    },
    {
      "matchPackageNames": [
        "ghcr.io/home-assistant/home-assistant",
        "eclipse-mosquitto",
        "koenkk/zigbee2mqtt",
        "nodered/node-red"
      ],
      "matchUpdateTypes": ["patch", "minor"],
      "groupName": "home automation",
      "automerge": false,
      "minimumReleaseAge": "14 days"
    },
    {
      "matchPackageNames": [
        "fluxcd/flux2",
        "cert-manager",
        "cloudflare/cloudflared",
        "binwiederhier/ntfy",
        "k8s-monitoring",
        "external-secrets",
        "cloudnative-pg",
        "oauth2-proxy",
        "ghcr.io/d0ugal/zigbee2mqtt-exporter"
      ],
      "matchUpdateTypes": ["patch", "minor"],
      "groupName": "infra tools",
      "automerge": true,
      "minimumReleaseAge": "5 days",
      "schedule": ["every weekend"]
    },
    {
      "matchUpdateTypes": ["patch"],
      "automerge": true,
      "schedule": ["every weekend"],
      "matchPackageNames": [
        "!ghcr.io/home-assistant/home-assistant",
        "!eclipse-mosquitto",
        "!koenkk/zigbee2mqtt",
        "!nodered/node-red"
      ]
    }
  ],
  "rebaseWhen": "behind-base-branch",
  "flux": {
    "managerFilePatterns": [
      "/\\.yaml$/"
    ]
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/\\.yaml$/"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/plans.yaml/"
      ],
      "matchStrings": [
        "version: (?<currentValue>v[0-9]+\\.[0-9]+\\.[0-9]+\\+k3s[0-9]+)"
      ],
      "depNameTemplate": "k3s",
      "versioningTemplate": "regex:^v(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)(?<compatibility>\\+k3s)(?<build>\\d+)$",
      "datasourceTemplate": "custom.k3s"
    }
  ],
  "customDatasources": {
    "k3s": {
      "defaultRegistryUrlTemplate": "https://update.k3s.io/v1-release/channels",
      "transformTemplates": [
        "{\"releases\":[{\"version\": $$.(data[id = 'stable'].latest),\"sourceUrl\":\"https://github.com/k3s-io/k3s\",\"changelogUrl\":$join([\"https://github.com/k3s-io/k3s/releases/tag/\",data[id = 'stable'].latest])}],\"sourceUrl\": \"https://github.com/k3s-io/k3s\",\"homepage\": \"https://k3s.io/\"}"
      ]
    }
  }
}
